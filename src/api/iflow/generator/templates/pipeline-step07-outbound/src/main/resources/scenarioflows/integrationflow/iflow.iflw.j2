<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    id="Definitions_1">

  <!-- ============================================================ -->
  <!-- Pipeline Step 07 Outbound — Collaboration                    -->
  <!-- ============================================================ -->
  <bpmn2:collaboration id="Collaboration_1" name="Default Collaboration">
    <bpmn2:extensionElements>
      <ifl:property>
        <key>namespaceMapping</key>
        <value>xmlns:ns={{ namespace }}</value>
      </ifl:property>
      <ifl:property>
        <key>allowedHeaderList</key>
        <value/>
      </ifl:property>
      <ifl:property>
        <key>ServerTrace</key>
        <value/>
      </ifl:property>
      <ifl:property>
        <key>returnExceptionToSender</key>
        <value/>
      </ifl:property>
      <ifl:property>
        <key>log</key>
        <value>All events</value>
      </ifl:property>
      <ifl:property>
        <key>cmdVariantUri</key>
        <value>ctype::IFlowVariant/cname::IFlowConfiguration</value>
      </ifl:property>
    </bpmn2:extensionElements>

    <!-- Sender: Pipeline framework calls this iFlow via ProcessDirect -->
    <bpmn2:participant id="Participant_Sender" ifl:type="EndpointSender"
        name="PipelineFramework">
      <bpmn2:extensionElements>
        <ifl:property>
          <key>enableBasicAuthentication</key>
          <value>false</value>
        </ifl:property>
        <ifl:property>
          <key>ifl:type</key>
          <value>EndpointSender</value>
        </ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:participant>

    <!-- Receiver Endpoint -->
    <bpmn2:participant id="Participant_Receiver" ifl:type="EndpointRecevier"
        name="{{ receiver_system | default('ReceiverSystem', true) }}">
      <bpmn2:extensionElements>
        <ifl:property>
          <key>ifl:type</key>
          <value>EndpointRecevier</value>
        </ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:participant>

    <!-- Integration Process -->
    <bpmn2:participant id="Participant_Process_1" ifl:type="IntegrationProcess"
        name="{{ iflow_name }}" processRef="Process_1">
      <bpmn2:extensionElements/>
    </bpmn2:participant>

    <!-- Sender Channel: ProcessDirect from Pipeline framework -->
    <bpmn2:messageFlow id="MessageFlow_Sender" name="ProcessDirect"
        sourceRef="Participant_Sender" targetRef="StartEvent_1">
      <bpmn2:extensionElements>
        <ifl:property>
          <key>ComponentType</key>
          <value>ProcessDirect</value>
        </ifl:property>
        <ifl:property>
          <key>Description</key>
          <value>Inbound from SAP CI Pipeline framework (Step 07)</value>
        </ifl:property>
        <ifl:property>
          <key>ComponentNS</key>
          <value>sap</value>
        </ifl:property>
        <ifl:property>
          <key>componentVersion</key>
          <value>1.1</value>
        </ifl:property>
        <ifl:property>
          <key>Name</key>
          <value>ProcessDirect</value>
        </ifl:property>
        <ifl:property>
          <key>TransportProtocolVersion</key>
          <value>1.1.2</value>
        </ifl:property>
        <ifl:property>
          <key>ComponentSWCVName</key>
          <value>external</value>
        </ifl:property>
        <ifl:property>
          <key>system</key>
          <value>PipelineFramework</value>
        </ifl:property>
        <ifl:property>
          <key>TransportProtocol</key>
          <value>Not Applicable</value>
        </ifl:property>
        <ifl:property>
          <key>cmdVariantUri</key>
          <value>ctype::AdapterVariant/cname::ProcessDirect/vendor::SAP/tp::Not Applicable/mp::Not Applicable/direction::Sender/version::1.1.1</value>
        </ifl:property>
        <ifl:property>
          <key>MessageProtocol</key>
          <value>Not Applicable</value>
        </ifl:property>
        <ifl:property>
          <key>MessageProtocolVersion</key>
          <value>1.1.2</value>
        </ifl:property>
        <ifl:property>
          <key>ComponentSWCVId</key>
          <value>1.1.2</value>
        </ifl:property>
        <ifl:property>
          <key>direction</key>
          <value>Sender</value>
        </ifl:property>
        <ifl:property>
          <key>address</key>
          <value>{% raw %}{{ProcessDirect_Address}}{% endraw %}</value>
        </ifl:property>
      </bpmn2:extensionElements>
    </bpmn2:messageFlow>

    <!-- Receiver Channel -->
    <bpmn2:messageFlow id="MessageFlow_Receiver" name="{{ receiver_component_type }}"
        sourceRef="EndEvent_1" targetRef="Participant_Receiver">
      <bpmn2:extensionElements>
        <ifl:property>
          <key>Description</key>
          <value/>
        </ifl:property>
        <ifl:property>
          <key>ComponentNS</key>
          <value>{{ receiver_component_ns }}</value>
        </ifl:property>
        <ifl:property>
          <key>componentVersion</key>
          <value>{{ receiver_component_version }}</value>
        </ifl:property>
        <ifl:property>
          <key>Name</key>
          <value>{{ receiver_component_type }}</value>
        </ifl:property>
        <ifl:property>
          <key>TransportProtocolVersion</key>
          <value>{{ receiver_version }}</value>
        </ifl:property>
        <ifl:property>
          <key>ComponentSWCVName</key>
          <value>external</value>
        </ifl:property>
        <ifl:property>
          <key>system</key>
          <value>{{ receiver_system | default('ReceiverSystem', true) }}</value>
        </ifl:property>
        <ifl:property>
          <key>TransportProtocol</key>
          <value>{{ receiver_transport_protocol }}</value>
        </ifl:property>
        <ifl:property>
          <key>cmdVariantUri</key>
          <value>{{ receiver_cmd_variant_uri }}</value>
        </ifl:property>
        <ifl:property>
          <key>MessageProtocol</key>
          <value>{{ receiver_message_protocol }}</value>
        </ifl:property>
        <ifl:property>
          <key>MessageProtocolVersion</key>
          <value>{{ receiver_version }}</value>
        </ifl:property>
        <ifl:property>
          <key>ComponentSWCVId</key>
          <value>{{ receiver_version }}</value>
        </ifl:property>
        <ifl:property>
          <key>direction</key>
          <value>Receiver</value>
        </ifl:property>
        <ifl:property>
          <key>ComponentType</key>
          <value>{{ receiver_component_type }}</value>
        </ifl:property>
        {% if receiver_adapter_type == 'HTTP' %}
        <ifl:property>
          <key>httpMethod</key>
          <value>{% raw %}{{receiverMethod}}{% endraw %}</value>
        </ifl:property>
        <ifl:property>
          <key>httpAddressWithoutQuery</key>
          <value>{% raw %}{{receiverHost}}{% endraw %}</value>
        </ifl:property>
        <ifl:property>
          <key>httpAddressQuery</key>
          <value>{% raw %}{{receiverQuery}}{% endraw %}</value>
        </ifl:property>
        <ifl:property>
          <key>authenticationMethod</key>
          <value>{% raw %}{{receiverAuthMethod}}{% endraw %}</value>
        </ifl:property>
        <ifl:property>
          <key>credentialName</key>
          <value>{% raw %}{{receiverAuth}}{% endraw %}</value>
        </ifl:property>
        <ifl:property>
          <key>throwExceptionOnFailure</key>
          <value>true</value>
        </ifl:property>
        <ifl:property>
          <key>proxyType</key>
          <value>{% raw %}{{receiverProxyType}}{% endraw %}</value>
        </ifl:property>
        <ifl:property>
          <key>httpRequestTimeout</key>
          <value>{% raw %}{{receiverTimeout}}{% endraw %}</value>
        </ifl:property>
        {% endif %}
      </bpmn2:extensionElements>
    </bpmn2:messageFlow>
  </bpmn2:collaboration>

  <!-- ============================================================ -->
  <!-- Main Integration Process (Step 07 outbound)                  -->
  <!-- No error subprocess — pipeline framework handles errors      -->
  <!-- ============================================================ -->
  <bpmn2:process id="Process_1" name="{{ iflow_name }}">
    <bpmn2:extensionElements>
      <ifl:property>
        <key>cmdVariantUri</key>
        <value>ctype::FlowElementVariant/cname::IntegrationProcess</value>
      </ifl:property>
    </bpmn2:extensionElements>

    <bpmn2:startEvent id="StartEvent_1" name="Start">
      <bpmn2:extensionElements>
        <ifl:property>
          <key>cmdVariantUri</key>
          <value>ctype::FlowstepVariant/cname::MessageStartEvent</value>
        </ifl:property>
      </bpmn2:extensionElements>
      <bpmn2:outgoing>SequenceFlow_1</bpmn2:outgoing>
      <bpmn2:messageEventDefinition/>
    </bpmn2:startEvent>

    <!-- Content Modifier: set pipeline headers -->
    <bpmn2:callActivity id="ServiceTask_ContentModifier" name="Set Pipeline Headers">
      <bpmn2:extensionElements>
        <ifl:property>
          <key>wrapContent</key>
          <value/>
        </ifl:property>
        <ifl:property>
          <key>activityType</key>
          <value>ContentModifier</value>
        </ifl:property>
        <ifl:property>
          <key>cmdVariantUri</key>
          <value>ctype::FlowstepVariant/cname::ContentModifier/version::{{ flowstep_versions.ContentModifier }}</value>
        </ifl:property>
        <ifl:property>
          <key>headerTable</key>
          <value>action:create:Name:SAP_PipelineScenarioId:Type:constant:Value:{{ iflow_id }}:Datatype::Default:|action:create:Name:SAP_PipelineStepName:Type:constant:Value:Step07_Outbound:Datatype::Default:|action:create:Name:SAP_ApplicationID:Type:constant:Value:{{ iflow_id }}:Datatype::Default:|action:create:Name:SAP_Sender:Type:constant:Value:{{ sender_system | default('PipelineFramework', true) }}:Datatype::Default:|action:create:Name:SAP_Receiver:Type:constant:Value:{{ receiver_system | default('ReceiverSystem', true) }}:Datatype::Default:|action:create:Name:SAP_MessageProcessingLogID:Type:expression:Value:${header.SAP_MessageProcessingLogID}:Datatype::Default:</value>
        </ifl:property>
        <ifl:property>
          <key>propertyTable</key>
          <value/>
        </ifl:property>
        <ifl:property>
          <key>bodyType</key>
          <value/>
        </ifl:property>
        <ifl:property>
          <key>body</key>
          <value/>
        </ifl:property>
      </bpmn2:extensionElements>
      <bpmn2:incoming>SequenceFlow_1</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_2</bpmn2:outgoing>
    </bpmn2:callActivity>

    {% if mapping_strategy == 'port' or mapping_strategy == 'rebuild' %}
    <bpmn2:callActivity id="CallActivity_Mapping" name="{{ mapping_reference | default('TODO_mapping', true) }}">
      <bpmn2:extensionElements>
        <ifl:property>
          <key>mappinguri</key>
          <value/>
        </ifl:property>
        <ifl:property>
          <key>mappingname</key>
          <value>{{ mapping_reference | default('TODO_mapping', true) }}</value>
        </ifl:property>
        <ifl:property>
          <key>mappingType</key>
          <value>{{ mapping_type | default('MessageMapping', true) }}</value>
        </ifl:property>
        <ifl:property>
          <key>mappingpath</key>
          <value/>
        </ifl:property>
        <ifl:property>
          <key>activityType</key>
          <value>Mapping</value>
        </ifl:property>
        <ifl:property>
          <key>cmdVariantUri</key>
          <value>ctype::FlowstepVariant/cname::MessageMapping</value>
        </ifl:property>
      </bpmn2:extensionElements>
      <bpmn2:incoming>SequenceFlow_2</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_3</bpmn2:outgoing>
    </bpmn2:callActivity>

    <bpmn2:sequenceFlow id="SequenceFlow_1" sourceRef="StartEvent_1" targetRef="ServiceTask_ContentModifier"/>
    <bpmn2:sequenceFlow id="SequenceFlow_2" sourceRef="ServiceTask_ContentModifier" targetRef="CallActivity_Mapping"/>
    <bpmn2:sequenceFlow id="SequenceFlow_3" sourceRef="CallActivity_Mapping" targetRef="EndEvent_1"/>
    {% else %}
    <bpmn2:sequenceFlow id="SequenceFlow_1" sourceRef="StartEvent_1" targetRef="ServiceTask_ContentModifier"/>
    <bpmn2:sequenceFlow id="SequenceFlow_2" sourceRef="ServiceTask_ContentModifier" targetRef="EndEvent_1"/>
    {% endif %}

    <bpmn2:endEvent id="EndEvent_1" name="End">
      <bpmn2:extensionElements>
        <ifl:property>
          <key>cmdVariantUri</key>
          <value>ctype::FlowstepVariant/cname::MessageEndEvent</value>
        </ifl:property>
      </bpmn2:extensionElements>
      {% if mapping_strategy == 'port' or mapping_strategy == 'rebuild' %}
      <bpmn2:incoming>SequenceFlow_3</bpmn2:incoming>
      {% else %}
      <bpmn2:incoming>SequenceFlow_2</bpmn2:incoming>
      {% endif %}
      <bpmn2:messageEventDefinition/>
    </bpmn2:endEvent>
  </bpmn2:process>

  <!-- ============================================================ -->
  <!-- Diagram layout                                                -->
  <!-- ============================================================ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1" name="Default Collaboration Diagram">
    <bpmndi:BPMNPlane bpmnElement="Collaboration_1" id="BPMNPlane_1">
      <bpmndi:BPMNShape bpmnElement="Participant_Receiver" id="BPMNShape_Participant_Receiver">
        <dc:Bounds height="140.0" width="120.0" x="713.0" y="10.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Participant_Sender" id="BPMNShape_Participant_Sender">
        <dc:Bounds height="140.0" width="120.0" x="-10.0" y="10.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="Participant_Process_1" id="BPMNShape_Participant_Process_1">
        <dc:Bounds height="200.0" width="459.0" x="200.0" y="0.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="StartEvent_1" id="BPMNShape_StartEvent_1">
        <dc:Bounds height="32.0" width="32.0" x="232.0" y="64.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="EndEvent_1" id="BPMNShape_EndEvent_1">
        <dc:Bounds height="32.0" width="32.0" x="564.0" y="64.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="ServiceTask_ContentModifier" id="BPMNShape_ServiceTask_ContentModifier">
        <dc:Bounds height="60.0" width="100.0" x="304.0" y="50.0"/>
      </bpmndi:BPMNShape>
      {% if mapping_strategy == 'port' or mapping_strategy == 'rebuild' %}
      <bpmndi:BPMNShape bpmnElement="CallActivity_Mapping" id="BPMNShape_CallActivity_Mapping">
        <dc:Bounds height="60.0" width="100.0" x="434.0" y="50.0"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_1" id="BPMNEdge_SequenceFlow_1" sourceElement="BPMNShape_StartEvent_1" targetElement="BPMNShape_ServiceTask_ContentModifier">
        <di:waypoint x="264.5" xsi:type="dc:Point" y="80.0"/>
        <di:waypoint x="304.5" xsi:type="dc:Point" y="80.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_2" id="BPMNEdge_SequenceFlow_2" sourceElement="BPMNShape_ServiceTask_ContentModifier" targetElement="BPMNShape_CallActivity_Mapping">
        <di:waypoint x="404.5" xsi:type="dc:Point" y="80.0"/>
        <di:waypoint x="434.5" xsi:type="dc:Point" y="80.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_3" id="BPMNEdge_SequenceFlow_3" sourceElement="BPMNShape_CallActivity_Mapping" targetElement="BPMNShape_EndEvent_1">
        <di:waypoint x="534.5" xsi:type="dc:Point" y="80.0"/>
        <di:waypoint x="564.5" xsi:type="dc:Point" y="80.0"/>
      </bpmndi:BPMNEdge>
      {% else %}
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_1" id="BPMNEdge_SequenceFlow_1" sourceElement="BPMNShape_StartEvent_1" targetElement="BPMNShape_ServiceTask_ContentModifier">
        <di:waypoint x="264.5" xsi:type="dc:Point" y="80.0"/>
        <di:waypoint x="304.5" xsi:type="dc:Point" y="80.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="SequenceFlow_2" id="BPMNEdge_SequenceFlow_2" sourceElement="BPMNShape_ServiceTask_ContentModifier" targetElement="BPMNShape_EndEvent_1">
        <di:waypoint x="404.5" xsi:type="dc:Point" y="80.0"/>
        <di:waypoint x="564.5" xsi:type="dc:Point" y="80.0"/>
      </bpmndi:BPMNEdge>
      {% endif %}
      <bpmndi:BPMNEdge bpmnElement="MessageFlow_Sender" id="BPMNEdge_MessageFlow_Sender" sourceElement="BPMNShape_Participant_Sender" targetElement="BPMNShape_StartEvent_1">
        <di:waypoint x="50.0" xsi:type="dc:Point" y="80.0"/>
        <di:waypoint x="248.0" xsi:type="dc:Point" y="80.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="MessageFlow_Receiver" id="BPMNEdge_MessageFlow_Receiver" sourceElement="BPMNShape_EndEvent_1" targetElement="BPMNShape_Participant_Receiver">
        <di:waypoint x="580.0" xsi:type="dc:Point" y="80.0"/>
        <di:waypoint x="773.0" xsi:type="dc:Point" y="80.0"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn2:definitions>
