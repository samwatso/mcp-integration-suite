<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<parameters>
  <!-- === SFTP Sender Parameters === -->
  <parameter>
    <key/>
    <name>SFTP_Sender_Host</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>SFTP sender host address</description>
    <additionalMetadata/>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Sender_Path</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>SFTP sender directory path</description>
    <additionalMetadata/>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Sender_FileName</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>SFTP sender file name pattern</description>
    <additionalMetadata/>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Sender_CredentialName</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>Security artifact name for SFTP sender authentication</description>
    <additionalMetadata/>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Sender_Authentication</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>Authentication method for SFTP sender</description>
    <additionalMetadata>
      <isCombobox>true</isCombobox>
    </additionalMetadata>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Sender_ProxyType</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>Proxy type for SFTP sender connection</description>
    <additionalMetadata>
      <isCombobox>true</isCombobox>
    </additionalMetadata>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Sender_PostProcessing</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>Post-processing action for successfully read files</description>
    <additionalMetadata>
      <isCombobox>true</isCombobox>
    </additionalMetadata>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Sender_Schedule</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>Polling schedule for SFTP sender</description>
    <additionalMetadata>
      <isCombobox>true</isCombobox>
    </additionalMetadata>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Sender_MaxBodySize</name>
    <type>xsd:integer</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>Maximum body size in MB for sender</description>
    <additionalMetadata/>
  </parameter>
  <!-- === SFTP Receiver Parameters === -->
  <parameter>
    <key/>
    <name>SFTP_Receiver_Host</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>SFTP receiver host address</description>
    <additionalMetadata/>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Receiver_Path</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>SFTP receiver directory path</description>
    <additionalMetadata/>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Receiver_FileName</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>SFTP receiver file name</description>
    <additionalMetadata/>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Receiver_CredentialName</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>Security artifact name for SFTP receiver authentication</description>
    <additionalMetadata/>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Receiver_Authentication</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>Authentication method for SFTP receiver</description>
    <additionalMetadata>
      <isCombobox>true</isCombobox>
    </additionalMetadata>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Receiver_ProxyType</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>Proxy type for SFTP receiver connection</description>
    <additionalMetadata>
      <isCombobox>true</isCombobox>
    </additionalMetadata>
  </parameter>
  <parameter>
    <key/>
    <name>SFTP_Receiver_Timeout</name>
    <type>xsd:integer</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>Connection timeout in milliseconds for SFTP receiver</description>
    <additionalMetadata/>
  </parameter>
{% include "script_parameters.propdef.j2" %}
  {% if error_handling_enabled %}
  <parameter>
    <key/>
    <name>ProcessDirect_Address</name>
    <type>xsd:string</type>
    <isRequired>false</isRequired>
    <constraint/>
    <description>ProcessDirect address for the error handling utility iFlow</description>
    <additionalMetadata/>
  </parameter>
  {% endif %}
  <param_references>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Sender/version::{{ adapter_versions.SFTP }}/attrId::host" attribute_uilabel="Address" param_key="SFTP_Sender_Host"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Sender/version::{{ adapter_versions.SFTP }}/attrId::path" attribute_uilabel="File Path" param_key="SFTP_Sender_Path"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Sender/version::{{ adapter_versions.SFTP }}/attrId::fileName" attribute_uilabel="File Name" param_key="SFTP_Sender_FileName"/>
