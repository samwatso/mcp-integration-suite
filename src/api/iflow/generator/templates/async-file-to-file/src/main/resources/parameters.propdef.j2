    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Sender/version::{{ adapter_versions.SFTP }}/attrId::authentication" attribute_uilabel="Authentication" param_key="SFTP_Sender_Authentication"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Sender/version::{{ adapter_versions.SFTP }}/attrId::proxyType" attribute_uilabel="Proxy Type" param_key="SFTP_Sender_ProxyType"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Sender/version::{{ adapter_versions.SFTP }}/attrId::postProcessing" attribute_uilabel="Post Processing" param_key="SFTP_Sender_PostProcessing"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Sender/version::{{ adapter_versions.SFTP }}/attrId::scheduleKey" attribute_uilabel="Schedule" param_key="SFTP_Sender_Schedule"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Sender/version::{{ adapter_versions.SFTP }}/attrId::maximumBodySize" attribute_uilabel="Maximum Body Size (in MB)" param_key="SFTP_Sender_MaxBodySize"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Receiver/version::{{ adapter_versions.SFTP }}/attrId::host" attribute_uilabel="Address" param_key="SFTP_Receiver_Host"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Receiver/version::{{ adapter_versions.SFTP }}/attrId::path" attribute_uilabel="File Path" param_key="SFTP_Receiver_Path"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Receiver/version::{{ adapter_versions.SFTP }}/attrId::fileName" attribute_uilabel="File Name" param_key="SFTP_Receiver_FileName"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Receiver/version::{{ adapter_versions.SFTP }}/attrId::tokenCredential" attribute_uilabel="Credential Name" param_key="SFTP_Receiver_CredentialName"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Receiver/version::{{ adapter_versions.SFTP }}/attrId::authentication" attribute_uilabel="Authentication" param_key="SFTP_Receiver_Authentication"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Receiver/version::{{ adapter_versions.SFTP }}/attrId::proxyType" attribute_uilabel="Proxy Type" param_key="SFTP_Receiver_ProxyType"/>
    <reference attribute_category="SFTP" attribute_id="ctype::AdapterVariant/cname::sap:SFTP/tp::SFTP/mp::File/direction::Receiver/version::{{ adapter_versions.SFTP }}/attrId::timeout" attribute_uilabel="Timeout (in ms)" param_key="SFTP_Receiver_Timeout"/>
