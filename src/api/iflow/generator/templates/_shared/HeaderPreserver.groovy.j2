import com.sap.gateway.ip.core.customdev.util.Message

/**
 * Header and property preservation across adapter hops.
 *
 * Critical for PI/PO migrations: PI's Adapter Engine automatically passes
 * dynamic configuration (filename, directory, receiver) between adapter
 * modules via the XI message header. CPI strips most headers between
 * certain adapter calls, causing migrated interfaces to silently lose
 * routing info, filenames, etc.
 *
 * Usage: place SAVE before an outbound adapter call, RESTORE after.
 * Control via exchange property:
 *   - HeaderPreserveMode : "SAVE" or "RESTORE" (set via Content Modifier)
 *
 * In SAVE mode, snapshots all non-internal headers + PI/PO-specific
 * properties into PRESERVED_* properties. In RESTORE mode, writes
 * them back as headers.
 *
 * Generated by Sashay Control Tower for iFlow: {{ iflow_id }}
 */
def Message processData(Message message) {
    def mode = message.getProperty("HeaderPreserveMode") ?: "SAVE"
    def prefix = "PRESERVED_HDR_"

    if (mode.equalsIgnoreCase("SAVE")) {
        // --- Snapshot all meaningful headers as properties ---
        message.getHeaders().each { k, v ->
            if (v != null && !k.startsWith("CamelAggregat") && !k.startsWith("org.apache")) {
                message.setProperty("${prefix}${k}", v.toString())
            }
        }

        // Also preserve PI/PO-specific dynamic configuration properties
        // These are commonly set by PI adapter modules and lost in CPI
        def piProperties = [
            "SenderService", "SenderParty", "ReceiverService", "ReceiverParty",
            "SenderInterface", "SenderNamespace", "ReceiverInterface", "ReceiverNamespace",
            "MessageId", "ConversationId", "DynamicConfiguration",
            "ASMA_SenderService", "ASMA_ReceiverService"
        ]
        piProperties.each { key ->
            def val = message.getProperty(key)
            if (val == null) val = message.getHeaders().get("SAP_${key}")
            if (val == null) val = message.getHeaders().get(key)
            if (val != null) message.setProperty("${prefix}${key}", val.toString())
        }

    } else if (mode.equalsIgnoreCase("RESTORE")) {
        // --- Restore preserved headers ---
        message.getProperties().findAll { it.key.startsWith(prefix) }.each { k, v ->
            def originalKey = k.substring(prefix.length())
            message.setHeader(originalKey, v)
        }
    }

    return message
}
