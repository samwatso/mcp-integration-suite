import com.sap.gateway.ip.core.customdev.util.Message

/**
 * Message replay snapshot — captures full context at iFlow entry.
 *
 * Place at the start of the integration process. On any downstream failure,
 * the MPL will contain a "Replay Snapshot" attachment with everything needed
 * to manually re-inject the message: original payload, all headers, and
 * exchange properties.
 *
 * Control via externalized parameter:
 *   - EnableReplaySnapshot : "true" to activate (default "false")
 *
 * This is especially useful during PI/PO migration testing: when an iFlow
 * fails, you can grab the snapshot from the MPL and re-send it without
 * needing access to the source system.
 *
 * Generated by Sashay Control Tower for iFlow: {{ iflow_id }}
 */
def Message processData(Message message) {
    def enabled = message.getProperty("EnableReplaySnapshot")?.toString()?.equalsIgnoreCase("true")
    if (!enabled) return message

    def messageLog = messageLogFactory.getMessageLog(message)
    if (messageLog == null) return message

    def snapshot = new StringBuilder()
    def timestamp = new Date().format("yyyy-MM-dd'T'HH:mm:ss.SSSZ")

    snapshot.append("=== REPLAY SNAPSHOT ===\n")
    snapshot.append("iFlow     : {{ iflow_name }} ({{ iflow_id }})\n")
    snapshot.append("Timestamp : ${timestamp}\n")
    snapshot.append("MPL ID    : ${message.getHeaders().get('SAP_MessageProcessingLogID') ?: 'N/A'}\n\n")

    // --- Headers (include Camel transport headers useful for replay) ---
    snapshot.append("=== Headers ===\n")
    message.getHeaders().each { k, v ->
        if (!k.startsWith("CamelAggregat") && !k.startsWith("org.apache") && v != null) {
            snapshot.append("${k} = ${v}\n")
        }
    }

    // --- Properties (exclude internal Camel bookkeeping) ---
    snapshot.append("\n=== Properties ===\n")
    message.getProperties().findAll {
        !it.key.startsWith("CamelCreated") && !it.key.startsWith("CamelToEndpoint")
    }.each { k, v ->
        if (v != null) snapshot.append("${k} = ${v}\n")
    }

    // --- Payload ---
    snapshot.append("\n=== Payload ===\n")
    def body = message.getBody(String)
    if (body != null) {
        def maxChars = 500000
        if (body.length() > maxChars) {
            snapshot.append(body.substring(0, maxChars))
            snapshot.append("\n[TRUNCATED at ${maxChars} chars — full size: ${body.length()}]")
        } else {
            snapshot.append(body)
        }
    } else {
        snapshot.append("[empty body]")
    }

    messageLog.addAttachmentAsString("Replay Snapshot", snapshot.toString(), "text/plain")

    return message
}
