import com.sap.gateway.ip.core.customdev.util.Message

/**
 * Dynamic filename and directory builder for file/SFTP scenarios.
 *
 * Replaces PI/PO's DynamicConfigurationBean and Java UDFs for dynamic
 * endpoint resolution. Reads filename/directory patterns from externalized
 * parameters and substitutes placeholders at runtime.
 *
 * Externalized parameters (set via Content Modifier or parameters.prop):
 *   - TargetFilenamePattern  : e.g. "ORDERS_{date}_{msgid}.xml"
 *   - TargetDirectoryPattern : e.g. "/outbound/{sender}/{date}"
 *
 * Supported placeholders:
 *   {date}      → yyyyMMdd
 *   {time}      → HHmmss
 *   {datetime}  → yyyyMMdd_HHmmss
 *   {timestamp} → yyyyMMdd'T'HHmmssSSS
 *   {msgid}     → MPL ID or generated UUID
 *   {sender}    → SenderService property
 *   {receiver}  → ReceiverService property
 *   {guid}      → random UUID
 *   {iflow}     → iFlow ID
 *
 * Sets CamelFileName and/or CamelFileDirectory headers for the
 * downstream SFTP/File adapter.
 *
 * Generated by Sashay Control Tower for iFlow: {{ iflow_id }}
 */
def Message processData(Message message) {
    def now = new Date()
    def props = message.getProperties()

    // Build substitution map
    def mplId = message.getHeaders().get("SAP_MessageProcessingLogID") ?: UUID.randomUUID().toString()
    def subs = [
        "{date}"     : now.format("yyyyMMdd"),
        "{time}"     : now.format("HHmmss"),
        "{datetime}" : now.format("yyyyMMdd_HHmmss"),
        "{timestamp}": now.format("yyyyMMdd'T'HHmmssSSS"),
        "{msgid}"    : mplId,
        "{sender}"   : props.get("SenderService") ?: props.get("PRESERVED_HDR_SenderService") ?: "UNKNOWN",
        "{receiver}" : props.get("ReceiverService") ?: props.get("PRESERVED_HDR_ReceiverService") ?: "UNKNOWN",
        "{guid}"     : UUID.randomUUID().toString(),
        "{iflow}"    : "{{ iflow_id }}",
    ]

    // --- Dynamic filename ---
    def filenamePattern = props.get("TargetFilenamePattern")
    if (filenamePattern) {
        def filename = filenamePattern
        subs.each { placeholder, value -> filename = filename.replace(placeholder, value) }
        message.setHeader("CamelFileName", filename)
    }

    // --- Dynamic directory ---
    def dirPattern = props.get("TargetDirectoryPattern")
    if (dirPattern) {
        def dir = dirPattern
        subs.each { placeholder, value -> dir = dir.replace(placeholder, value) }
        message.setHeader("CamelFileDirectory", dir)
    }

    return message
}
