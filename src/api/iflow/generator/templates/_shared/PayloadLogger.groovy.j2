import com.sap.gateway.ip.core.customdev.util.Message

/**
 * Configurable payload logger for SAP CPI iFlows.
 *
 * Replaces separate "before/after" scripts with a single reusable script.
 * Place at any checkpoint in the flow; control via exchange properties:
 *
 *   - LogPointName   : label for the MPL attachment (e.g. "Before Mapping")
 *   - EnablePayloadLogging : "true" to activate (externalized parameter)
 *   - LogHeaders     : "true" to also capture headers/properties context
 *
 * Handles: payload truncation (CPI MPL ~1 MB limit), auto MIME detection,
 * and optional header/property snapshot for debugging PI/PO migrations.
 *
 * Generated by Sashay Control Tower for iFlow: {{ iflow_id }}
 */
def Message processData(Message message) {
    def enableLogging = message.getProperty("EnablePayloadLogging")?.toString()?.equalsIgnoreCase("true")
    if (!enableLogging) return message

    def logPoint = message.getProperty("LogPointName") ?: "Checkpoint"
    def logHeaders = message.getProperty("LogHeaders")?.toString()?.equalsIgnoreCase("true")

    def messageLog = messageLogFactory.getMessageLog(message)
    if (messageLog == null) return message

    // --- Payload attachment (with truncation for large messages) ---
    def body = message.getBody(String)
    if (body != null) {
        def maxChars = 500000  // ~500 KB safe limit for MPL attachments
        def truncated = (body.length() > maxChars) ? body.substring(0, maxChars) + "\n[TRUNCATED at ${maxChars} chars — full size: ${body.length()}]" : body

        // Auto-detect content type from payload
        def contentType = message.getHeaders().get("Content-Type") ?: "application/xml"
        def trimmed = body.trim()
        if (trimmed.startsWith("{") || trimmed.startsWith("[")) {
            contentType = "application/json"
        } else if (trimmed.startsWith("<")) {
            contentType = "application/xml"
        }

        messageLog.addAttachmentAsString("Payload - ${logPoint}", truncated, contentType)
    }

    messageLog.setStringProperty("LogPoint", logPoint)

    // --- Optional: headers and properties context ---
    if (logHeaders) {
        def meta = new StringBuilder()
        meta.append("=== Exchange Headers ===\n")
        message.getHeaders().findAll { !it.key.startsWith("Camel") || it.key in [
            "CamelFileName", "CamelFileDirectory", "CamelHttpMethod",
            "CamelHttpUri", "CamelHttpResponseCode"
        ]}.each { k, v ->
            meta.append("  ${k} = ${v}\n")
        }

        meta.append("\n=== Exchange Properties ===\n")
        message.getProperties().findAll {
            !it.key.startsWith("CamelAggregat") && !it.key.startsWith("CamelCreated")
        }.each { k, v ->
            meta.append("  ${k} = ${v}\n")
        }

        messageLog.addAttachmentAsString("Context - ${logPoint}", meta.toString(), "text/plain")
    }

    return message
}
