// BRIDGE ENTRY POINT — called from the iFlow Script step
// ═══════════════════════════════════════════════════════════════════════

def Message processData(Message message) {
    def messageLog = messageLogFactory.getMessageLog(message)
    def props = message.getProperties()

    // Build compatibility objects from CPI message
    def trace = new MappingTrace()

    def containerParams = [:]
    props.each { k, v ->
        if (v != null && !k.startsWith("Camel") && !k.startsWith("SAP_")) {
            containerParams[k] = v.toString()
        }
    }
    def container = new MappingContainer(containerParams)

    def headerFields = [
        "SenderService"     : props.get("SenderService") ?: props.get("PRESERVED_HDR_SenderService") ?: "{{ sender_system }}",
        "SenderParty"       : props.get("SenderParty") ?: "",
        "ReceiverService"   : props.get("ReceiverService") ?: props.get("PRESERVED_HDR_ReceiverService") ?: "{{ receiver_system }}",
        "ReceiverParty"     : props.get("ReceiverParty") ?: "",
        "Interface"         : "{{ iflow_name }}",
        "InterfaceNamespace": "{{ namespace }}",
        "MessageId"         : message.getHeaders().get("SAP_MessageProcessingLogID") ?: UUID.randomUUID().toString(),
    ]
    def inputHeader = new InputHeader(headerFields)

    // Get input payload
    def inputPayload = message.getBody(String)
    if (inputPayload == null) inputPayload = ""

    // === Execute the ported mapping logic ===
    def outputPayload
    try {
        // Build a params map that the ported code can use
        // This combines: container params + header fields + exchange properties
        def allParams = [:]
        allParams.putAll(containerParams)
        allParams.putAll(headerFields)
        allParams.put("_trace", trace)
        allParams.put("_container", container)
        allParams.put("_inputHeader", inputHeader)

        outputPayload = portedMappingLogic(inputPayload, allParams, trace, container, inputHeader)

    } catch (Exception e) {
        trace.addWarning("Mapping execution failed: ${e.getMessage()}")
        // Log the error but don't swallow it — let the exception subprocess handle it
        if (messageLog != null) {
            messageLog.addAttachmentAsString("Java Mapping Bridge Error", """\
Error: ${e.getMessage()}
Input payload size: ${inputPayload.length()} chars
Trace:
${trace.getTraceText()}""", "text/plain")
        }
        throw e
    }

    // Set output
    if (outputPayload != null) {
        message.setBody(outputPayload)
    }

    // Write mapping trace to MPL (emulates PI/PO trace tab)
    if (messageLog != null && trace.getEntries().size() > 0) {
        messageLog.addAttachmentAsString(
            "Java Mapping Trace",
            trace.getTraceText(),
            "text/plain"
        )
    }

    // Write back any container parameters the mapping set (for downstream steps)
    container.getParameters().each { k, v ->
        if (!containerParams.containsKey(k) || containerParams[k] != v) {
            message.setProperty(k, v?.toString() ?: "")
        }
    }

    return message
}


