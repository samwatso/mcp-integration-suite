/**
 * Emulates com.sap.aii.mapping.api.MappingTrace.
 * In PI/PO, this writes to the message monitor trace tab.
 * In CPI, we redirect to MPL attachments.
 */
class MappingTrace {
    private List<String> entries = []

    void addInfo(String text) { entries << "[INFO]  ${text}" }
    void addWarning(String text) { entries << "[WARN]  ${text}" }
    void addDebugMessage(String text) { entries << "[DEBUG] ${text}" }

    String getTraceText() { return entries.join("\n") }
    List<String> getEntries() { return entries }
}

/**
 * Emulates com.sap.aii.mapping.api.Container and GlobalContainer.
 * In PI/PO, these pass parameters between mapping steps.
 * In CPI, backed by exchange properties.
 */
class MappingContainer {
    private Map<String, Object> params = [:]

    MappingContainer(Map<String, Object> initialParams) {
        this.params = initialParams ?: [:]
    }

    Object getParameter(String name) { return params.get(name) }
    void setParameter(String name, Object value) { params.put(name, value) }
    Map<String, Object> getParameters() { return params }
}

/**
 * Emulates com.sap.aii.mapping.api.InputHeader.
 * In PI/PO, provides access to XI message header fields.
 */
class InputHeader {
    private Map<String, String> fields = [:]

    InputHeader(Map<String, String> fields) {
        this.fields = fields ?: [:]
    }

    String getFieldValue(String name) { return fields.get(name) ?: "" }

    // Common PI/PO header field accessors
    String getSenderService() { return getFieldValue("SenderService") }
    String getSenderParty() { return getFieldValue("SenderParty") }
    String getReceiverService() { return getFieldValue("ReceiverService") }
    String getReceiverParty() { return getFieldValue("ReceiverParty") }
    String getInterface() { return getFieldValue("Interface") }
    String getInterfaceNamespace() { return getFieldValue("InterfaceNamespace") }
    String getMessageId() { return getFieldValue("MessageId") }
}

/**
 * Emulates com.sap.aii.mapping.api.RuntimeConstants.
 */
class RuntimeConstants {
    static final String SENDER_SERVICE = "SenderService"
    static final String SENDER_PARTY = "SenderParty"
    static final String RECEIVER_SERVICE = "ReceiverService"
    static final String RECEIVER_PARTY = "ReceiverParty"
