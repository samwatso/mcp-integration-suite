import com.sap.gateway.ip.core.customdev.util.Message
import java.io.PrintWriter
import java.io.StringWriter

/**
 * Generic exception handler with error source classification.
 *
 * Place in the exception subprocess. Classifies the exception by source
 * (HTTP, connectivity, mapping, auth, runtime) and sets exchange properties
 * that downstream steps can use for routing to different error channels.
 *
 * Sets properties:
 *   - ErrorSource    : HTTP_OUTBOUND | CONNECTIVITY | MAPPING | AUTH | RUNTIME | UNKNOWN
 *   - ErrorDetail    : human-readable error description
 *   - ErrorTimestamp : ISO-8601 timestamp
 *   - ErrorIFlowId   : iFlow identifier (for correlation in alerting)
 *
 * Also logs error detail + stack trace as MPL attachments, and preserves the
 * original payload at the point of failure for replay support.
 *
 * Generated by Sashay Control Tower for iFlow: {{ iflow_id }}
 */
def Message processData(Message message) {
    def messageLog = messageLogFactory.getMessageLog(message)
    def ex = message.getProperty("CamelExceptionCaught")
    def httpCode = message.getProperty("CamelHttpResponseCode")
    def timestamp = new Date().format("yyyy-MM-dd'T'HH:mm:ss.SSSZ")

    // --- Classify error source ---
    def errorSource = "UNKNOWN"
    def errorDetail = "No exception details available"
    def stackTrace = ""

    if (ex != null) {
        errorDetail = ex.getMessage() ?: ex.toString()

        // Capture stack trace
        def sw = new StringWriter()
        ex.printStackTrace(new PrintWriter(sw))
        stackTrace = sw.toString()

        def className = ex.getClass().getCanonicalName() ?: ""
        switch (className) {
            case ~/.*AhcOperationFailedException/:
                errorSource = "HTTP_OUTBOUND"
                try {
                    errorDetail = "HTTP ${ex.getStatusCode()}: ${ex.getStatusText()}\n${ex.getResponseBody()}"
                } catch (ignored) {
                    // getResponseBody() may not be available on all versions
                }
                break
            case ~/.*ConnectException/:
            case ~/.*SocketTimeoutException/:
            case ~/.*UnknownHostException/:
            case ~/.*NoRouteToHostException/:
                errorSource = "CONNECTIVITY"
                break
            case ~/.*SAXParseException/:
            case ~/.*TransformerException/:
            case ~/.*XPathException/:
                errorSource = "MAPPING"
                break
            case ~/.*AuthenticationException/:
            case ~/.*SecurityException/:
            case ~/.*SSLException/:
            case ~/.*CertificateException/:
                errorSource = "AUTH"
                break
            case ~/.*JMSException/:
                errorSource = "JMS"
                break
            default:
                errorSource = "RUNTIME"
        }
    }

    // --- Set properties for downstream routing / alerting ---
    message.setProperty("ErrorSource", errorSource)
    message.setProperty("ErrorDetail", errorDetail)
    message.setProperty("ErrorTimestamp", timestamp)
    message.setProperty("ErrorIFlowId", "{{ iflow_id }}")
    message.setProperty("ErrorIFlowName", "{{ iflow_name }}")

    // Custom header for monitoring systems (survives into MPL custom headers)
    message.setHeader("SAP_ApplicationID", "{{ iflow_id }}")

    // --- Log to MPL ---
    if (messageLog != null) {
        messageLog.setStringProperty("ErrorSource", errorSource)
        messageLog.setStringProperty("ErrorIFlowId", "{{ iflow_id }}")

        messageLog.addAttachmentAsString("Error Detail", """\
Error Source : ${errorSource}
Timestamp    : ${timestamp}
iFlow        : {{ iflow_name }} ({{ iflow_id }})

${errorDetail}""", "text/plain")

        if (stackTrace) {
            def maxTrace = 100000
            def truncatedTrace = (stackTrace.length() > maxTrace) ? stackTrace.substring(0, maxTrace) + "\n[TRUNCATED]" : stackTrace
            messageLog.addAttachmentAsString("Stack Trace", truncatedTrace, "text/plain")
        }

        // Preserve original payload at point of failure for replay
        try {
            def originalBody = message.getBody(String)
            if (originalBody) {
                def maxBody = 500000
                def truncatedBody = (originalBody.length() > maxBody) ? originalBody.substring(0, maxBody) + "\n[TRUNCATED]" : originalBody
                messageLog.addAttachmentAsString("Payload at Error", truncatedBody, "application/xml")
            }
        } catch (ignored) {
            // Body may not be readable in all error scenarios
        }
    }

    // --- Build structured error body for downstream error channels ---
    def errorBody = """<errorReport>
  <iFlowId>{{ iflow_id }}</iFlowId>
  <iFlowName>{{ iflow_name }}</iFlowName>
  <errorSource>${errorSource}</errorSource>
  <timestamp>${timestamp}</timestamp>
  <error><![CDATA[${errorDetail}]]></error>
</errorReport>"""

    message.setBody(errorBody)
    message.setHeader("Content-Type", "application/xml")

    return message
}
