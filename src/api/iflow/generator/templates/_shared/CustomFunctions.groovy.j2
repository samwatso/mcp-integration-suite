// 1. STRING MANIPULATION
// ═══════════════════════════════════════════════════════════════════════

/**
 * Left-pad a string to a fixed width. Replaces PI/PO UDF "leftPad".
 * Common for SAP material numbers (18 chars), document numbers, etc.
 *
 * leftPad("12345", 10, "0") → "0000012345"
 */
static String leftPad(String input, int length, String padChar = "0") {
    if (input == null) return padChar.multiply(length)
    return input.padLeft(length, padChar)
}

/**
 * Right-pad a string to a fixed width.
 *
 * rightPad("ABC", 10, " ") → "ABC       "
 */
static String rightPad(String input, int length, String padChar = " ") {
    if (input == null) return padChar.multiply(length)
    return input.padRight(length, padChar)
}

/**
 * Remove leading zeros from SAP number fields.
 * Replaces PI/PO standard function "removeLeadingZeros".
 *
 * removeLeadingZeros("0000012345") → "12345"
 * removeLeadingZeros("0000000000") → "0"
 */
static String removeLeadingZeros(String input) {
    if (input == null || input.isEmpty()) return input
    def result = input.replaceFirst("^0+", "")
    return result.isEmpty() ? "0" : result
}

/**
 * Add leading zeros to match SAP field length (typically 10 or 18).
 *
 * addLeadingZeros("12345", 10) → "0000012345"
 */
static String addLeadingZeros(String input, int length = 10) {
    return leftPad(input?.trim() ?: "", length, "0")
}

/**
 * Safe substring that won't throw IndexOutOfBounds.
 * Common in PI/PO when source fields are longer than target.
 *
 * safeSubstring("ABCDEF", 0, 3) → "ABC"
 * safeSubstring("AB", 0, 10) → "AB"
 * safeSubstring(null, 0, 5) → ""
 */
static String safeSubstring(String input, int start, int end) {
    if (input == null) return ""
    if (start >= input.length()) return ""
    return input.substring(start, Math.min(end, input.length()))
}

/**
 * Convert between character encodings. Common for legacy system integration.
 */
static String convertEncoding(String input, String fromEncoding, String toEncoding) {
    if (input == null) return null
    return new String(input.getBytes(fromEncoding), toEncoding)
}

/**
 * Replace special characters that cause XML parsing issues.
 * Useful for free-text fields from legacy systems.
 */
static String sanitizeForXml(String input) {
    if (input == null) return null
    return input
        .replace("&", "&amp;")
        .replace("<", "&lt;")
        .replace(">", "&gt;")
        .replace("\"", "&quot;")
        .replace("'", "&apos;")
        .replaceAll("[\\x00-\\x08\\x0B\\x0C\\x0E-\\x1F]", "")  // Remove control chars
}

/**
 * Split a delimited string into a list. Replaces PI/PO UDF "splitByDelimiter".
 *
 * splitString("A;B;C", ";") → ["A", "B", "C"]
 */
static List<String> splitString(String input, String delimiter) {
    if (input == null || input.isEmpty()) return []
    return input.split(java.util.regex.Pattern.quote(delimiter)).toList()
}


