// 5. XML / JSON UTILITIES
// ═══════════════════════════════════════════════════════════════════════

/**
 * Extract a value from XML using a simple XPath-like expression.
 * Does NOT require javax.xml.xpath — uses Groovy's GPath.
 *
 * extractXmlValue("<root><a><b>hello</b></a></root>", "a.b") → "hello"
 */
static String extractXmlValue(String xml, String path) {
    if (xml == null || path == null) return ""
    try {
        def doc = new XmlSlurper().parseText(xml)
        def parts = path.split("\\.")
        def node = doc
        for (part in parts) {
            node = node."${part}"
        }
        return node?.text()?.trim() ?: ""
    } catch (Exception e) {
        return ""
    }
}

/**
 * Strip all XML namespace prefixes and declarations.
 * Common when mapping between namespaced and non-namespaced formats.
 *
 * stripNamespaces("<ns0:Root xmlns:ns0='urn:test'><ns0:Item/></ns0:Root>")
 * → "<Root><Item/></Root>"
 */
static String stripNamespaces(String xml) {
    if (xml == null) return null
    // Remove namespace prefixes from elements
    def result = xml.replaceAll("<(/?)\\w+:", '<$1')
    // Remove xmlns declarations
    result = result.replaceAll("\\s+xmlns(:\\w+)?\\s*=\\s*[\"'][^\"']*[\"']", "")
    return result.trim()
}

/**
 * Wrap a value in a CDATA section. Useful for free-text fields.
 */
static String wrapCdata(String input) {
    if (input == null) return "<![CDATA[]]>"
    return "<![CDATA[${input}]]>"
}

/**
 * Escape a JSON string value.
 */
static String escapeJson(String input) {
    if (input == null) return ""
    return input
        .replace("\\", "\\\\")
        .replace("\"", "\\\"")
        .replace("\n", "\\n")
        .replace("\r", "\\r")
        .replace("\t", "\\t")
}


