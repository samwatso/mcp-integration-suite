// 2. DATE/TIME CONVERSION
// ═══════════════════════════════════════════════════════════════════════

/**
 * Convert between date formats. The #1 most-used UDF in PI/PO migrations.
 *
 * SAP internal:     "20260407"     (yyyyMMdd)
 * SAP time:         "143000"       (HHmmss)
 * SAP timestamp:    "20260407143000" (yyyyMMddHHmmss)
 * ISO 8601:         "2026-04-07T14:30:00Z"
 * IDoc date:        "20260407"
 * RFC/BAPI:         "2026-04-07"
 * Display:          "07.04.2026"   (dd.MM.yyyy, German)
 *
 * convertDate("20260407", "yyyyMMdd", "yyyy-MM-dd") → "2026-04-07"
 * convertDate("2026-04-07", "yyyy-MM-dd", "yyyyMMdd") → "20260407"
 */
static String convertDate(String input, String fromFormat, String toFormat, String timezone = "UTC") {
    if (input == null || input.trim().isEmpty()) return ""
    try {
        def sdfFrom = new SimpleDateFormat(fromFormat)
        sdfFrom.setTimeZone(TimeZone.getTimeZone(timezone))
        sdfFrom.setLenient(false)
        def date = sdfFrom.parse(input.trim())
        def sdfTo = new SimpleDateFormat(toFormat)
        sdfTo.setTimeZone(TimeZone.getTimeZone(timezone))
        return sdfTo.format(date)
    } catch (Exception e) {
        return ""  // Return empty on unparseable date (same as PI/PO standard function)
    }
}

/**
 * Shortcut: SAP internal date (yyyyMMdd) → ISO date (yyyy-MM-dd).
 */
static String sapDateToIso(String sapDate) {
    return convertDate(sapDate, "yyyyMMdd", "yyyy-MM-dd")
}

/**
 * Shortcut: ISO date (yyyy-MM-dd) → SAP internal date (yyyyMMdd).
 */
static String isoDateToSap(String isoDate) {
    return convertDate(isoDate, "yyyy-MM-dd", "yyyyMMdd")
}

/**
 * SAP timestamp (yyyyMMddHHmmss) → ISO 8601 (yyyy-MM-dd'T'HH:mm:ss'Z').
 */
static String sapTimestampToIso(String sapTimestamp) {
    return convertDate(sapTimestamp, "yyyyMMddHHmmss", "yyyy-MM-dd'T'HH:mm:ss'Z'")
}

/**
 * Get current date/time in a given format. Replaces PI/PO "CurrentDate" function.
 */
static String currentDate(String format = "yyyyMMdd", String timezone = "UTC") {
    def sdf = new SimpleDateFormat(format)
    sdf.setTimeZone(TimeZone.getTimeZone(timezone))
    return sdf.format(new Date())
}

/**
 * Get current SAP timestamp (yyyyMMddHHmmss).
 */
static String currentSapTimestamp() {
    return currentDate("yyyyMMddHHmmss")
}

/**
 * Add or subtract days from a date. Used in delivery date calculations.
 *
 * addDays("20260407", "yyyyMMdd", 5) → "20260412"
 * addDays("20260407", "yyyyMMdd", -1) → "20260406"
 */
static String addDays(String input, String format, int days) {
    if (input == null || input.trim().isEmpty()) return ""
    try {
        def sdf = new SimpleDateFormat(format)
        sdf.setTimeZone(TimeZone.getTimeZone("UTC"))
        def cal = Calendar.getInstance()
        cal.setTime(sdf.parse(input.trim()))
        cal.add(Calendar.DAY_OF_MONTH, days)
        return sdf.format(cal.getTime())
    } catch (Exception e) {
        return ""
    }
}


