/**
 * Extract IDoc control record field values. Useful when the IDoc XML
 * structure needs to be inspected in a pre-mapping script.
 */
static String getIDocControlField(String idocXml, String fieldName) {
    if (idocXml == null) return ""
    try {
        def doc = new XmlSlurper().parseText(idocXml)
        def control = doc.'**'.find { it.name() == 'EDI_DC40' || it.name() == 'EDIDC' }
        if (control == null) return ""
        def field = control.'*'.find { it.name() == fieldName }
        return field?.text()?.trim() ?: ""
    } catch (Exception e) {
        return ""
    }
}

/**
 * Get IDoc message type from control record.
 */
static String getIDocMessageType(String idocXml) {
    return getIDocControlField(idocXml, "MESTYP")
}

/**
 * Get IDoc type (basic type) from control record.
 */
static String getIDocType(String idocXml) {
    return getIDocControlField(idocXml, "IDOCTYP")
}

/**
 * Build a BAPI return structure element.
 *
 * buildBapiReturn("S", "000", "Success") →
 *   <RETURN><TYPE>S</TYPE><ID>000</ID><MESSAGE>Success</MESSAGE></RETURN>
 */
static String buildBapiReturn(String type, String id, String message, String number = "000") {
    return """<RETURN><TYPE>${type}</TYPE><ID>${id}</ID><NUMBER>${number}</NUMBER><MESSAGE>${sanitizeForXml(message)}</MESSAGE></RETURN>"""
}


