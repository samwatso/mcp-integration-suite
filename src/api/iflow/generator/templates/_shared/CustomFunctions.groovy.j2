// 6. LOOKUP AND DEFAULT VALUE HANDLING
// ═══════════════════════════════════════════════════════════════════════

/**
 * Return the first non-null, non-empty value from a list.
 * Replaces PI/PO's "if exists" → "use source A, else source B" pattern.
 *
 * coalesce("", null, "fallback") → "fallback"
 * coalesce("value", "other") → "value"
 */
static String coalesce(String... values) {
    for (v in values) {
        if (v != null && !v.trim().isEmpty()) return v.trim()
    }
    return ""
}

/**
 * Return a default value if input is null or empty.
 *
 * defaultIfEmpty(null, "N/A") → "N/A"
 * defaultIfEmpty("hello", "N/A") → "hello"
 */
static String defaultIfEmpty(String input, String defaultValue) {
    return (input != null && !input.trim().isEmpty()) ? input.trim() : defaultValue
}

/**
 * Simple value mapping / cross-reference lookup.
 * Replaces PI/PO value mapping tables.
 *
 * mapValue("01", ["01": "PO", "02": "SO", "03": "DN"], "UNKNOWN") → "PO"
 */
static String mapValue(String input, Map<String, String> mapping, String defaultValue = "") {
    if (input == null) return defaultValue
    return mapping.getOrDefault(input.trim(), defaultValue)
}

/**
 * Case-insensitive value mapping.
 */
static String mapValueIgnoreCase(String input, Map<String, String> mapping, String defaultValue = "") {
    if (input == null) return defaultValue
    def key = input.trim().toUpperCase()
    def upperMapping = mapping.collectEntries { k, v -> [k.toUpperCase(), v] }
    return upperMapping.getOrDefault(key, defaultValue)
}


// ═══════════════════════════════════════════════════════════════════════
// 7. CONDITIONAL MAPPING HELPERS
// ═══════════════════════════════════════════════════════════════════════

/**
 * Conditional output: if condition is true, return trueValue; else falseValue.
 *
 * ifThenElse("X", "Active", "Inactive") → "Active"
 * ifThenElse("", "Active", "Inactive") → "Inactive"
 * ifThenElse(null, "Active", "Inactive") → "Inactive"
 */
static String ifThenElse(String condition, String trueValue, String falseValue) {
    return (condition != null && !condition.trim().isEmpty() && condition.trim() != "0" && condition.trim().toUpperCase() != "FALSE")
        ? trueValue : falseValue
}

/**
 * Check if a field exists (non-null, non-empty). Returns "true"/"false".
 * Useful for conditional segment creation in IDoc mappings.
 */
static String exists(String input) {
    return (input != null && !input.trim().isEmpty()) ? "true" : "false"
}

/**
 * Return input only if it matches a regex pattern, otherwise return empty.
 * Useful for field validation in mappings.
 *
 * matchOrEmpty("12345", "\\d+") → "12345"
 * matchOrEmpty("abc", "\\d+") → ""
 */
static String matchOrEmpty(String input, String pattern) {
    if (input == null) return ""
    return input.trim().matches(pattern) ? input.trim() : ""
}

/**
 * Boolean flag mapping: SAP "X"/"" to "true"/"false" and back.
 *
 * sapBoolToString("X") → "true"
 * sapBoolToString("") → "false"
 * stringToSapBool("true") → "X"
 * stringToSapBool("false") → ""
 */
static String sapBoolToString(String sapFlag) {
    return (sapFlag?.trim()?.toUpperCase() == "X") ? "true" : "false"
}

static String stringToSapBool(String boolString) {
    return (boolString?.trim()?.toUpperCase() in ["TRUE", "1", "YES", "X"]) ? "X" : ""
}


