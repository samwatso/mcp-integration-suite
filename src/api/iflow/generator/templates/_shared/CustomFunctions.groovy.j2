// 3. NUMBER FORMATTING
// ═══════════════════════════════════════════════════════════════════════

/**
 * Format a number with specific decimal places.
 * Handles SAP's quirks: trailing minus for negatives, comma decimals.
 *
 * formatNumber("1234.56", 2) → "1234.56"
 * formatNumber("1234", 2) → "1234.00"
 * formatNumber("1234.5678", 2) → "1234.57"
 */
static String formatNumber(String input, int decimals = 2) {
    if (input == null || input.trim().isEmpty()) return ""
    try {
        // Handle SAP trailing minus: "1234.56-" → "-1234.56"
        def clean = input.trim()
        if (clean.endsWith("-")) {
            clean = "-" + clean.substring(0, clean.length() - 1)
        }
        // Handle comma as decimal separator
        clean = clean.replace(",", ".")
        def number = new BigDecimal(clean)
        def pattern = "0" + (decimals > 0 ? "." + "0".multiply(decimals) : "")
        def df = new DecimalFormat(pattern)
        return df.format(number)
    } catch (Exception e) {
        return ""
    }
}

/**
 * Convert SAP quantity/amount format to standard decimal.
 * SAP often sends "1.234,56" (German) or "1234.56-" (negative).
 *
 * sapNumberToDecimal("1.234,56") → "1234.56"
 * sapNumberToDecimal("1234.56-") → "-1234.56"
 */
static String sapNumberToDecimal(String input) {
    if (input == null || input.trim().isEmpty()) return ""
    def clean = input.trim()
    def isNegative = clean.endsWith("-")
    if (isNegative) clean = clean.substring(0, clean.length() - 1)
    // Detect German format (period as thousands, comma as decimal)
    if (clean.contains(",") && clean.indexOf(",") > clean.lastIndexOf(".")) {
        clean = clean.replace(".", "").replace(",", ".")
    } else if (clean.contains(",") && !clean.contains(".")) {
        clean = clean.replace(",", ".")
    }
    return (isNegative ? "-" : "") + clean
}

/**
 * Convert a decimal to SAP internal format (no separators, fixed decimals).
 *
 * decimalToSapNumber("1234.56", 2) → "123456"
 * decimalToSapNumber("-1234.56", 2) → "123456-"
 */
static String decimalToSapNumber(String input, int decimals = 2) {
    if (input == null || input.trim().isEmpty()) return ""
    try {
        def number = new BigDecimal(input.trim())
        def isNegative = number < 0
        number = number.abs().movePointRight(decimals)
        def result = number.toBigInteger().toString()
        return isNegative ? result + "-" : result
    } catch (Exception e) {
        return ""
    }
}

/**
 * Convert between unit of measure codes. Common in IDoc mappings.
 * SAP internal UoM (3 chars, e.g. "ST", "KG") ↔ ISO code (e.g. "EA", "KGM").
 */
static String mapUnitOfMeasure(String sapUom, Map<String, String> mapping = null) {
    def defaultMap = [
        "ST": "EA", "EA": "ST",    // Each/Stück
        "KG": "KGM", "KGM": "KG",  // Kilogram
        "M": "MTR", "MTR": "M",    // Meter
        "L": "LTR", "LTR": "L",    // Liter
        "TO": "TNE", "TNE": "TO",  // Tonne
        "PC": "EA", "PCE": "EA",   // Piece
        "M2": "MTK", "MTK": "M2",  // Square meter
        "M3": "MTQ", "MTQ": "M3",  // Cubic meter
    ]
    def lookupMap = mapping ?: defaultMap
    return lookupMap.get(sapUom?.trim()?.toUpperCase(), sapUom ?: "")
}


