/**
 * Convert SAP language key (1-char) to ISO 639-1 (2-char) and back.
 */
static String sapLangToIso(String sapLang) {
    def map = [
        "D": "DE", "E": "EN", "F": "FR", "I": "IT", "S": "ES",
        "P": "PT", "N": "NL", "J": "JA", "K": "KO", "1": "ZH",
        "R": "RU", "T": "TH", "U": "TR", "W": "PL", "6": "CS",
    ]
    return map.getOrDefault(sapLang?.trim()?.toUpperCase(), sapLang ?: "")
}

static String isoLangToSap(String isoLang) {
    def map = [
        "DE": "D", "EN": "E", "FR": "F", "IT": "I", "ES": "S",
        "PT": "P", "NL": "N", "JA": "J", "KO": "K", "ZH": "1",
        "RU": "R", "TH": "T", "TR": "U", "PL": "W", "CS": "6",
    ]
    return map.getOrDefault(isoLang?.trim()?.toUpperCase(), isoLang ?: "")
}

/**
 * Convert SAP country code to ISO 3166-1 alpha-2 (usually the same,
 * but SAP has exceptions: GB vs UK, etc.).
 */
static String sapCountryToIso(String sapCountry) {
    def exceptions = ["GB": "UK"]  // Add more as needed per customer
    return exceptions.getOrDefault(sapCountry?.trim()?.toUpperCase(), sapCountry?.trim()?.toUpperCase() ?: "")
}

/**
 * Format SAP material number: remove leading zeros for external systems,
 * or pad to 18 characters for SAP-bound messages.
 */
static String formatMaterialNumber(String matnr, boolean forSap = false) {
    if (matnr == null || matnr.trim().isEmpty()) return ""
    return forSap ? addLeadingZeros(matnr.trim(), 18) : removeLeadingZeros(matnr.trim())
}

/**
 * Format SAP partner number (KUNNR/LIFNR): 10 chars with leading zeros.
 */
static String formatPartnerNumber(String partner, boolean forSap = false) {
    if (partner == null || partner.trim().isEmpty()) return ""
    return forSap ? addLeadingZeros(partner.trim(), 10) : removeLeadingZeros(partner.trim())
}
