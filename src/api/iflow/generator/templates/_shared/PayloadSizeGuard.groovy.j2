import com.sap.gateway.ip.core.customdev.util.Message

/**
 * Payload size guard — reject oversized messages early.
 *
 * PI/PO has adapter-level size limits. CPI's limits are different and
 * less obvious: 40 MB for Cloud Connector payloads, memory-based limits
 * on the tenant (shared JVM). Migrated interfaces that handled large
 * files in PI/PO can silently cause OOM or timeout in CPI.
 *
 * This script makes the limit explicit and configurable per-iFlow
 * via externalized parameter:
 *   - MaxPayloadSizeMB : maximum allowed payload in MB (default 10)
 *   - EnableSizeGuard  : "true" to activate (default "true")
 *
 * On oversized payload: sets PayloadOversized=true property, logs to
 * MPL, and throws an exception caught by the exception subprocess.
 *
 * Generated by Sashay Control Tower for iFlow: {{ iflow_id }}
 */
def Message processData(Message message) {
    def enabled = message.getProperty("EnableSizeGuard")?.toString()
    // Default to enabled unless explicitly set to "false"
    if (enabled != null && enabled.equalsIgnoreCase("false")) return message

    def maxSizeMB = 10
    try {
        def configuredMax = message.getProperty("MaxPayloadSizeMB")
        if (configuredMax) maxSizeMB = Integer.parseInt(configuredMax.toString())
    } catch (NumberFormatException ignored) {}

    def body = message.getBody(byte[])
    if (body == null) return message

    def sizeMB = body.length / (1024.0 * 1024.0)
    def sizeFormatted = String.format("%.2f", sizeMB)

    message.setProperty("PayloadSizeMB", sizeFormatted)

    if (sizeMB > maxSizeMB) {
        message.setProperty("PayloadOversized", "true")

        def messageLog = messageLogFactory.getMessageLog(message)
        if (messageLog != null) {
            messageLog.setStringProperty("PayloadSizeMB", sizeFormatted)
            messageLog.setStringProperty("PayloadOversized", "true")
            messageLog.setStringProperty("ErrorIFlowId", "{{ iflow_id }}")
        }

        throw new Exception(
            "Payload size ${sizeFormatted} MB exceeds configured limit of ${maxSizeMB} MB " +
            "[iFlow: {{ iflow_id }}]. Increase MaxPayloadSizeMB or split the payload."
        )
    }

    return message
}
