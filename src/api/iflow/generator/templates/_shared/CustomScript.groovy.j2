import com.sap.gateway.ip.core.customdev.util.Message
import groovy.xml.XmlSlurper
import groovy.xml.StreamingMarkupBuilder
import groovy.xml.XmlUtil

/**
 * CustomScript.groovy — Multi-purpose iFlow script with selectable entry points.
 *
 * Each method is a separate entry point callable from a Script step.
 * Set the scriptFunction property in the iFlow to choose which one runs.
 *
 * Methods:
 *   processData            — default (no-op pass-through)
 *   setCustomHeaders       — set common SAP/CPI headers from properties
 *   convertCsvToXml        — transform CSV payload to XML
 *   convertXmlToJson       — transform XML payload to JSON
 *   convertJsonToXml       — transform JSON payload to XML
 *   stripXmlNamespaces     — remove all namespace prefixes and declarations
 *   extractAndSetHeaders   — pull values from XML payload into headers
 *   buildSoapEnvelope      — wrap payload in SOAP envelope (for PI/PO SOAP flows)
 *   unwrapSoapEnvelope     — extract body from SOAP envelope
 *   splitPayloadToAttachments — split repeating XML elements into attachments
 *   mergeAttachmentsToPayload — reassemble attachments into single payload
 *   base64EncodeBody       — Base64-encode the message body
 *   base64DecodeBody       — Base64-decode the message body
 *   compressBody           — GZIP-compress the message body
 *   decompressBody         — GZIP-decompress the message body
 *
 * Generated by Sashay Control Tower for iFlow: {{ iflow_id }}
 */


// ═══════════════════════════════════════════════════════════════════════
// DEFAULT ENTRY POINT
// ═══════════════════════════════════════════════════════════════════════

def Message processData(Message message) {
    // No-op pass-through — override via scriptFunction property
    return message
}


// ═══════════════════════════════════════════════════════════════════════
// HEADER MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════

/**
 * Set standard SAP/CPI headers from exchange properties or defaults.
 * Useful at iFlow entry to establish routing context that downstream
 * adapter calls expect.
 *
 * Reads from properties: SenderService, ReceiverService, MessageType, etc.
 * Sets headers: SAP_Sender, SAP_Receiver, SAP_MessageType, Content-Type, etc.
 */
def Message setCustomHeaders(Message message) {
    def props = message.getProperties()

    // SAP routing headers (used by content-based routing, monitoring)
    def senderService = props.get("SenderService") ?: "{{ sender_system }}"
    def receiverService = props.get("ReceiverService") ?: "{{ receiver_system }}"
    message.setHeader("SAP_Sender", senderService)
    message.setHeader("SAP_Receiver", receiverService)
    message.setHeader("SAP_ApplicationID", "{{ iflow_id }}")

    // Content-Type detection
    def body = message.getBody(String)
    if (body != null) {
        def trimmed = body.trim()
        if (trimmed.startsWith("{") || trimmed.startsWith("[")) {
            message.setHeader("Content-Type", "application/json; charset=utf-8")
        } else if (trimmed.startsWith("<")) {
            message.setHeader("Content-Type", "application/xml; charset=utf-8")
        }
    }

    // Correlation ID (for end-to-end tracing across systems)
    def correlationId = props.get("CorrelationId") ?: message.getHeaders().get("X-CorrelationID") ?: UUID.randomUUID().toString()
    message.setHeader("X-CorrelationID", correlationId)
    message.setProperty("CorrelationId", correlationId)

    return message
}


// ═══════════════════════════════════════════════════════════════════════
// FORMAT CONVERSION
// ═══════════════════════════════════════════════════════════════════════

/**
 * Convert CSV payload to XML.
 * First row = header names → element names.
 * Properties: CsvDelimiter (default ","), CsvRootElement (default "Records"),
 *             CsvRowElement (default "Record").
 */
def Message convertCsvToXml(Message message) {
    def body = message.getBody(String)
    if (body == null || body.trim().isEmpty()) return message

    def delimiter = message.getProperty("CsvDelimiter") ?: ","
    def rootElement = message.getProperty("CsvRootElement") ?: "Records"
    def rowElement = message.getProperty("CsvRowElement") ?: "Record"

    def lines = body.trim().split("\n")
    if (lines.length < 2) return message

    def headers = lines[0].split(java.util.regex.Pattern.quote(delimiter)).collect { it.trim().replaceAll("[^a-zA-Z0-9_]", "_") }

    def xml = new StringBuilder()
    xml.append("<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n")
    xml.append("<${rootElement}>\n")

    for (int i = 1; i < lines.length; i++) {
        def values = lines[i].split(java.util.regex.Pattern.quote(delimiter), -1)
        xml.append("  <${rowElement}>\n")
        for (int j = 0; j < Math.min(headers.size(), values.size()); j++) {
            def value = values[j].trim()
            // Escape XML special chars
            value = value.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
            xml.append("    <${headers[j]}>${value}</${headers[j]}>\n")
        }
        xml.append("  </${rowElement}>\n")
    }
    xml.append("</${rootElement}>")

    message.setBody(xml.toString())
    message.setHeader("Content-Type", "application/xml; charset=utf-8")
    return message
}

/**
 * Convert XML payload to JSON.
 * Uses Groovy's JsonOutput for correct escaping.
 */
def Message convertXmlToJson(Message message) {
    def body = message.getBody(String)
    if (body == null || body.trim().isEmpty()) return message

    def xml = new XmlSlurper().parseText(body)
    def json = groovy.json.JsonOutput.toJson(xmlToMap(xml))
    message.setBody(groovy.json.JsonOutput.prettyPrint(json))
    message.setHeader("Content-Type", "application/json; charset=utf-8")
    return message
}

/**
 * Convert JSON payload to XML.
 * Property: JsonRootElement (default "Root").
 */
def Message convertJsonToXml(Message message) {
    def body = message.getBody(String)
    if (body == null || body.trim().isEmpty()) return message

    def rootElement = message.getProperty("JsonRootElement") ?: "Root"
    def json = new groovy.json.JsonSlurper().parseText(body)

    def writer = new StringWriter()
    def xml = new MarkupBuilder(writer)
    xml.setDoubleQuotes(true)

    xml."${rootElement}" {
        jsonToXmlHelper(xml, json)
    }

    message.setBody("<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n" + writer.toString())
    message.setHeader("Content-Type", "application/xml; charset=utf-8")
    return message
}


// ═══════════════════════════════════════════════════════════════════════
// XML MANIPULATION
// ═══════════════════════════════════════════════════════════════════════

/**
 * Strip all namespace prefixes and xmlns declarations from XML payload.
 * Common when target system doesn't understand source namespaces.
 */
def Message stripXmlNamespaces(Message message) {
    def body = message.getBody(String)
    if (body == null) return message

    // Remove namespace prefixes from elements
    def result = body.replaceAll("<(/?)\\w+:", '<$1')
    // Remove xmlns declarations
    result = result.replaceAll("\\s+xmlns(:\\w+)?\\s*=\\s*[\"'][^\"']*[\"']", "")

    message.setBody(result)
    return message
}

/**
 * Extract values from XML payload and set them as exchange headers/properties.
 * Reads property: XPathExtractions — semicolon-separated list of "headerName=xpath.path" pairs.
 *
 * Example property value: "OrderNumber=Header.OrderId;CustomerCode=Header.CustomerId"
 */
def Message extractAndSetHeaders(Message message) {
    def body = message.getBody(String)
    def extractions = message.getProperty("XPathExtractions")
    if (body == null || extractions == null) return message

    def xml = new XmlSlurper().parseText(body)

    extractions.split(";").each { extraction ->
        def parts = extraction.trim().split("=", 2)
        if (parts.length == 2) {
            def headerName = parts[0].trim()
            def pathExpr = parts[1].trim()
            def node = xml
            pathExpr.split("\\.").each { segment -> node = node."${segment}" }
            def value = node?.text()?.trim() ?: ""
            if (value) {
                message.setHeader(headerName, value)
                message.setProperty(headerName, value)
            }
        }
    }

    return message
}

/**
 * Wrap the payload body in a SOAP 1.1 envelope.
 * Useful when migrating PI/PO SOAP interfaces where CPI adapter
 * doesn't auto-wrap.
 */
def Message buildSoapEnvelope(Message message) {
    def body = message.getBody(String)
    if (body == null) return message

    def soapAction = message.getProperty("SoapAction") ?: message.getHeaders().get("SOAPAction") ?: ""

    def envelope = """<?xml version="1.0" encoding="UTF-8"?>
<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/">
  <soap:Header/>
  <soap:Body>
${body}
  </soap:Body>
</soap:Envelope>"""

    message.setBody(envelope)
    message.setHeader("Content-Type", "text/xml; charset=utf-8")
    if (soapAction) message.setHeader("SOAPAction", soapAction)
    return message
}

/**
 * Extract the body content from a SOAP envelope.
 */
def Message unwrapSoapEnvelope(Message message) {
    def body = message.getBody(String)
    if (body == null) return message

    try {
        def envelope = new XmlSlurper().parseText(body)
        def soapBody = envelope.'**'.find { it.name() == 'Body' }
        if (soapBody != null && soapBody.children().size() > 0) {
            def content = XmlUtil.serialize(soapBody.children()[0])
            // Remove XML declaration added by serialize
            content = content.replaceFirst("<\\?xml[^?]*\\?>\\s*", "")
            message.setBody(content)
        }
    } catch (Exception e) {
        // If not SOAP, leave body unchanged
    }
    return message
}


// ═══════════════════════════════════════════════════════════════════════
// ENCODING / COMPRESSION
// ═══════════════════════════════════════════════════════════════════════

/**
 * Base64-encode the message body. Useful for binary-to-text conversion
 * when target adapter doesn't support binary.
 */
def Message base64EncodeBody(Message message) {
    def body = message.getBody(byte[])
    if (body == null) return message
    message.setBody(Base64.getEncoder().encodeToString(body))
    return message
}

/**
 * Base64-decode the message body.
 */
def Message base64DecodeBody(Message message) {
    def body = message.getBody(String)
    if (body == null) return message
    message.setBody(new String(Base64.getDecoder().decode(body.trim())))
    return message
}

/**
 * GZIP-compress the message body. Sets Content-Encoding header.
 */
def Message compressBody(Message message) {
    def body = message.getBody(byte[])
    if (body == null) return message

    def baos = new ByteArrayOutputStream()
    def gzip = new java.util.zip.GZIPOutputStream(baos)
    gzip.write(body)
    gzip.close()

    message.setBody(baos.toByteArray())
    message.setHeader("Content-Encoding", "gzip")
    return message
}

/**
 * GZIP-decompress the message body.
 */
def Message decompressBody(Message message) {
    def body = message.getBody(byte[])
    if (body == null) return message

    def gzip = new java.util.zip.GZIPInputStream(new ByteArrayInputStream(body))
    def result = gzip.bytes
    gzip.close()

    message.setBody(new String(result, "UTF-8"))
    message.getHeaders().remove("Content-Encoding")
    return message
}


// ═══════════════════════════════════════════════════════════════════════
// INTERNAL HELPERS (not callable as entry points)
// ═══════════════════════════════════════════════════════════════════════

private Map xmlToMap(def node) {
    def map = [:]
    if (node.children().size() == 0) {
        return node.text()
    }
    node.children().each { child ->
        def name = child.name()
        def value = xmlToMap(child)
        if (map.containsKey(name)) {
            if (!(map[name] instanceof List)) {
                map[name] = [map[name]]
            }
            map[name] << value
        } else {
            map[name] = value
        }
    }
    return map
}

private void jsonToXmlHelper(def xml, def json) {
    if (json instanceof Map) {
        json.each { key, value ->
            if (value instanceof List) {
                value.each { item ->
                    xml."${key}" {
                        jsonToXmlHelper(xml, item)
                    }
                }
            } else if (value instanceof Map) {
                xml."${key}" {
                    jsonToXmlHelper(xml, value)
                }
            } else {
                xml."${key}"(value?.toString() ?: "")
            }
        }
    }
}
